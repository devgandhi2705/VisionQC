# ================================================================
#  VisionQC — .gitignore
#  NOTE: Model checkpoints, static assets, Images/, demo_images/,
#  and other/ are intentionally TRACKED (not ignored).
# ================================================================

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
venv/
env/
.env/
.venv/
ENV/

# Environment variables / secrets
.env
.env.local
*.env

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# Logs
*.log
logs/

# Pytest / coverage
.pytest_cache/
htmlcov/
.coverage
*.cover

# Build / dist
dist/
build/
*.egg-info/

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Flask session files
flask_session/

# Torch compiled cache
*.onnx
