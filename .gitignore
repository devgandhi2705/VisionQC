# ================================================================
#  VisionQC — .gitignore
# ================================================================

# Model checkpoints
*.pt

# Asset folders (large binary files — not needed in git)
demo_images/
other/
static/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
venv/
env/
.env/
.venv/
ENV/

# Environment variables / secrets
.env
.env.local
*.env

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# Logs
*.log
logs/

# Pytest / coverage
.pytest_cache/
htmlcov/
.coverage
*.cover

# Build / dist
dist/
build/
*.egg-info/

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Flask session files
flask_session/

# Torch compiled cache
*.onnx
